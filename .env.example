# Climent Ads Assistant — local example
# Copy to .env for local development. Never commit real values.

NODE_ENV=development
PORT=4177
HOST=127.0.0.1

# Demo mode serves synthetic fixtures and needs no provider credentials.
CLIMENT_ADS_ASSISTANT_DEMO_MODE=true

# --- Full self-host build only (not needed for the demo) ---
# Provider OAuth is operator-approved and read-only. These are placeholders.
# META_APP_ID=your_meta_app_id
# META_APP_SECRET=your_meta_app_secret
# META_REDIRECT_URI=http://localhost:4177/auth/meta/callback
# META_OAUTH_STATE_SECRET=replace_with_local_random_value
# META_GRAPH_API_VERSION=v20.0

# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret
# GOOGLE_REDIRECT_URI=http://localhost:4177/auth/google/callback
# GOOGLE_ADS_DEVELOPER_TOKEN=your_google_ads_developer_token
# GOOGLE_ADS_API_VERSION=v21

# Local-only token encryption key. Use a strong random value in real deployments.
# TOKEN_ENCRYPTION_KEY=replace_with_32_byte_local_secret
